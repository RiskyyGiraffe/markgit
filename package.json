{
  "name": "tolty",
  "private": true,
  "packageManager": "pnpm@9.13.1",
  "scripts": {
    "dev": "pnpm --filter @tolty/api dev",
    "dev:web": "pnpm --filter @tolty/web dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @tolty/api build",
    "build:web": "pnpm --filter @tolty/web build",
    "db:generate": "pnpm --filter @tolty/api db:generate",
    "db:migrate": "pnpm --filter @tolty/api db:migrate",
    "db:seed": "pnpm --filter @tolty/api db:seed",
    "test": "pnpm -r test",
    "deploy:api": "./scripts/deploy-api.sh"
  },
  "engines": {
    "node": ">=20"
  }
}
