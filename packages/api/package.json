{
  "name": "@tolty/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./db/schema": "./src/db/schema.ts",
    "./lib/crypto": "./src/lib/crypto.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.6.0",
    "postgres": "^3.4.0",
    "stripe": "^20.4.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
